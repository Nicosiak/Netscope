{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "NetScope: Run",
      "type": "shell",
      "command": "bash scripts/run_app.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "NetScope: Stop (port 8765)",
      "type": "shell",
      "command": "make stop",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ]
}
